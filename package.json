{
  "name": "mfe-workbench",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx ng serve core --port 4200",
    "build": "npx ng build",
    "build:libs": "npx ng build shared-ui && npx ng build shared-auth && npx ng build shared-events",
    "build:mfe1": "npx ng build mfe1",
    "build:mfe2": "npx ng build mfe2",
    "build:core": "npx ng build core",
    "build:production": "npm run build:libs && npm run build:mfe1 && npm run build:mfe2 && npm run build:core",
    "build:production:manifest": "node scripts/generate-manifest.js && npm run build:production",
    "build:clean": "rimraf dist && npm run build:production",
    "manifest:dev": "node scripts/generate-manifest.js",
    "watch": "npx ng build --watch --configuration development",
    "test": "npx ng test"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "16.2",
    "@angular/animations": "^16.2.0",
    "@angular/cdk": "^16.2.14",
    "@angular/common": "^16.2.0",
    "@angular/compiler": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/forms": "^16.2.0",
    "@angular/material": "^16.2.14",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/router": "^16.2.0",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.16",
    "@angular/cli": "^16.2.16",
    "@angular/compiler-cli": "^16.2.0",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^16.2.0",
    "typescript": "~5.1.3"
  }
}